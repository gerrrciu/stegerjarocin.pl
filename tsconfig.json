{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "ESNext",
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",

    /* Tryb Bundlera (Vite) */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* KLUCZOWE: To mówi TS, jak obsługiwać import.meta.glob, pliki CSS oraz grafiki */
    "types": ["vite/client"],

    /* Wsparcie dla importów typów i grafik */
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    /* Ścieżki mapowane względem katalogu głównego */
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Luźniejsze sprawdzanie błędów dla sprawnego buildu */
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "generate-thumbnails.mjs"],
  "references": [{ "path": "./tsconfig.node.json" }]
}